# ─────────────────────────────────────────────────────────────────────────────
# LearningGuide — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values you need.
# The app works without any AI keys — they're only needed for AI generation.
#
#   cp .env.example .env
#
# NEVER commit your .env file to Git! (.gitignore already excludes it)
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# Default: SQLite file in the current directory. Change if you want a
# different file path or a different database (e.g., PostgreSQL).
# DATABASE_URL=sqlite:///./learningguide.db

# ── AI Provider: Groq (recommended — fast & free tier) ───────────────────────
# Get a free key at: https://console.groq.com
# GROQ_API_KEY=gsk_...

# ── AI Provider: OpenAI ───────────────────────────────────────────────────────
# Get a key at: https://platform.openai.com
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1  # Change this for other providers

# ── AI Provider: Ollama (local, no key needed) ────────────────────────────────
# Install Ollama from https://ollama.com, then run: ollama pull llama3.2
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2
